# Secrets / local env — never bake into the image
.env
copy.env

# VCS / CI
.git
.gitignore
Jenkinsfile

# Python caches and virtualenvs
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/

# Logs and temp
logs/
*.log
*.tmp

# Editor / OS cruft
.vscode/
.idea/
.DS_Store
Thumbs.db

# NOTE: tests/, requirements-dev.txt and pyproject.toml are intentionally kept
# in the build context so the Dockerfile "test" stage can run the suite. The
# runtime stage copies only app/ + requirements.txt, so they don't end up in
# the final image.
