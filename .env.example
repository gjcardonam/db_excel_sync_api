# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# --- Logging ---
LOG_LEVEL=INFO
# Set to true to also write rotating log files (off by default; stdout is always on).
LOG_TO_FILE=false
LOG_FILE=logs/app.log

# --- CORS ---
# Comma-separated allowed origins. "*" allows any origin (internal API).
CORS_ALLOW_ORIGINS=*

# --- Audit logging to Postgres ---
# When LOG_DB_HOST is set, structured logs are persisted asynchronously.
LOG_DB_ENABLED=true
LOG_DB_HOST=your-db-host.rds.amazonaws.com
LOG_DB_PORT=5432
LOG_DB_NAME=postgres
LOG_DB_USER=postgres
LOG_DB_PASSWORD=changeme
LOG_DB_TABLE=db_excel_sync_api_logs
LOG_DB_LEVEL=INFO

# --- Integration tests (optional) ---
# When set, tests/integration run against this Postgres (throwaway schema per test).
# IT_DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/db

# --- Per-company operational databases ---
# For each company, define <COMPANY>_HOST, <COMPANY>_DATABASE, <COMPANY>_USER,
# <COMPANY>_PASSWORD, <COMPANY>_PORT, <COMPANY>_SCHEMA. Example for company "ACME":
# ACME_HOST=...
# ACME_DATABASE=...
# ACME_USER=...
# ACME_PASSWORD=...
# ACME_PORT=5432
# ACME_SCHEMA=public
